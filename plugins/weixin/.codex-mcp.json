{
  "mcpServers": {
    "weixin": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-c",
        "bun install --no-summary --cwd \"${CODEX_PLUGIN_ROOT:-.}\" 1>&2 && exec bun --cwd \"${CODEX_PLUGIN_ROOT:-.}\" server-codex.ts"
      ],
      "env": {
        "CODEX_WS_URL": "ws://127.0.0.1:4500"
      }
    }
  }
}
