{
  "name": "cc-weixin",
  "version": "0.1.2",
  "description": "WeChat channel plugin for Claude Code and Codex via official iLink Bot API",
  "license": "MIT",
  "type": "module",
  "bin": {
    "server": "./server.ts",
    "server-codex": "./server-codex.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qufei1993/cc-weixin.git",
    "directory": "plugins/weixin"
  },
  "homepage": "https://github.com/qufei1993/cc-weixin",
  "bugs": "https://github.com/qufei1993/cc-weixin/issues",
  "author": "qufei1993",
  "keywords": [
    "weixin",
    "wechat",
    "claude-code",
    "codex",
    "mcp",
    "channel",
    "ilink-bot",
    "clawbot"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun install --no-summary && bun server.ts",
    "start:codex": "bun install --no-summary && bun server-codex.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "qrcode-terminal": "0.12.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
